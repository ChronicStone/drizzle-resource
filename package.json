{
  "name": "drizzle-resource",
  "version": "1.0.0",
  "description": "Schema-driven, type-safe query resources for Drizzle ORM — filtering, sorting, pagination, search, and facets behind one typed contract",
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "facets",
    "filters",
    "pagination",
    "query",
    "sorting",
    "typescript"
  ],
  "files": [
    "build",
    "README.md"
  ],
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --config .oxlintrc.json --deny-warnings",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "bunx vitest run",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "build": "bun run compile",
    "prepack": "bun run build",
    "pack:check": "npm pack --dry-run",
    "docs:build": "cd docs && bun run build",
    "docs:check": "cd docs && bun run twoslash:verify",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build && bun run pack:check",
    "ci": "bun run check && bun run docs:check",
    "changeset": "changeset",
    "release:status": "changeset status --verbose",
    "release:version": "changeset version && bun install",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "drizzle-orm": "1.0.0-beta.16-ea816b6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "drizzle-orm": ">=1.0.0-beta"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "./index.ts"
    ],
    "fixedExtension": false,
    "format": "esm",
    "minify": "dce-only",
    "outDir": "./build",
    "sourcemaps": false,
    "target": "esnext",
    "treeshake": false
  },
  "packageManager": "bun@1.3.6"
}
